{
  "version": 2,
  "buildCommand": "echo 'Python build complete'",
  "outputDirectory": ".",
  "functions": {
    "api/health.py": {
      "runtime": "python3.11"
    },
    "api/predict.py": {
      "runtime": "python3.11",
      "maxDuration": 60
    },
    "api/chat.py": {
      "runtime": "python3.11"
    }
  },
  "routes": [
    {
      "src": "/health",
      "dest": "api/health.py"
    },
    {
      "src": "/predict",
      "dest": "api/predict.py"
    },
    {
      "src": "/chat",
      "dest": "api/chat.py"
    },
    {
      "src": "/(.*)",
      "dest": "api/health.py"
    }
  ],
  "env": {
    "PYTHONUNBUFFERED": "1"
  }
}
